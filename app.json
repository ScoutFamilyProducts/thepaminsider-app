{
  "expo": {
    "name": "The PAM Field Guide",
    "slug": "pam-field-guide",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#050607"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletOS": false,
      "bundleIdentifier": "com.thepaminsider.pamfieldguide"
    },
    "android": {
      "package": "com.thepaminsider.pamfieldguide",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050607"
      },
      "permissions": []
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [],
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0
    }
  }
}
